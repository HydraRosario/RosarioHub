# YouTube API - Get from Google Cloud Console
YOUTUBE_API_KEY=your_youtube_api_key

# Cron Job Secret - Generate a random string for automated snapshots
# Set this in Vercel Dashboard > Project > Environment Variables
CRON_SECRET=generate_a_random_secret_here

# Optional: Supabase (not currently used)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
