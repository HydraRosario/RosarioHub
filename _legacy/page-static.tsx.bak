import {
    Instagram, Youtube, Music2, MessageCircle,
    ExternalLink, MapPin, TrendingUp, Mic2, Play,
    Mail, Zap, Radio,
} from 'lucide-react'

// Importamos tu theme engine
import {
    ThemeContext,
    getThemeDefinition,
    injectFonts,
} from './themeEngine'

/* ─────────────────────────────────────────────────────────────
   HOOK: Real-time Spotify Listeners
───────────────────────────────────────────────────────────── */
function useSpotifyStats(artistId: string) {
    const [items, setItems] = useState<any[]>([]);

    useEffect(() => {
        if (!artistId) return;
        const fetchStats = async () => {
            try {
                // Usamos una alternativa más robusta
                const response = await fetch(`https://open.spotify.com/artist/${artistId}`, {
                    headers: {
                        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
                    }
                });
                
                if (!response.ok) {
                    throw new Error('Failed to fetch Spotify data');
                }
                
                const html = await response.text();
                const results = [];

                // 1. Oyentes
                const listenersRegex = /([\d.,KMB]+)\s*(?:monthly listeners|oyentes mensuales)/i;
                const lMatch = html.match(listenersRegex);
                if (lMatch) {
                    results.push({ label: 'Spotify Oyentes', value: lMatch[1], platform: 'spotify', isLive: true });
                }

                // 2. Play count del top track (Discovery)
                const playsRegex = /\"playCount\":\s*\"(\d+)\"/i;
                const pMatch = html.match(playsRegex);
                if (pMatch) {
                    const val = parseInt(pMatch[1]);
                    const formatted = val > 1000 ? (val / 1000).toFixed(1) + 'K' : val;
                    results.push({ label: 'Top Track Plays', value: formatted, platform: 'spotify', isLive: true });
                }

                setItems(results);
            } catch (err) {
                console.error("Error fetching Spotify stats:", err);
                // En caso de error, mostramos datos de ejemplo
                setItems([
                    { label: 'Spotify Oyentes', value: '25K', platform: 'spotify', isLive: false },
                    { label: 'Top Track Plays', value: '1.2M', platform: 'spotify', isLive: false }
                ]);
            }
        };
        fetchStats();
    }, [artistId]);

    return items;
}

/* ─────────────────────────────────────────────────────────────
   HOOK: Real-time YouTube Subscribers
───────────────────────────────────────────────────────────── */
function useYoutubeStats(channelId: string) {
    const [items, setItems] = useState<any[]>([]);

    useEffect(() => {
        if (!channelId) return;
        const fetchStats = async () => {
            try {
                // Usamos una alternativa más robusta
                const response = await fetch(`https://www.youtube.com/channel/${channelId}/about?hl=en`, {
                    headers: {
                        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
                    }
                });
                
                if (!response.ok) {
                    throw new Error('Failed to fetch YouTube data');
                }
                
                const html = await response.text();
                const results = [];

                // 1. Suscriptores (Multi-regex para robustez)
                const subsMatch = html.match(/\"subscriberCountText\":\{\"accessibility\":\{\"accessibilityData\":\{\"label\":\"([\d.,KMB]+)\s*subscribers/i) ||
                    html.match(/\"label\":\"([\d.,KMB]+)\s*suscriptores/i) ||
                    html.match(/\"content\":\"([\d.,KMB]+)\s*suscriptores/i) ||
                    html.match(/>([\d.,KMB]+)\s*subscribers/i);
                if (subsMatch) {
                    results.push({ label: 'YouTube Subs', value: subsMatch[1], platform: 'youtube', isLive: true });
                }

                // 2. Vistas totales
                const viewsMatch = html.match(/([\d.,]+)\s*views/i) || html.match(/([\d.,]+)\s*vistas/i);
                if (viewsMatch) {
                    results.push({ label: 'YouTube Views', value: viewsMatch[1], platform: 'youtube', isLive: true });
                }

                if (results.length > 0) setItems(results);
            } catch (err) {
                console.error("Error fetching YouTube stats:", err);
                // En caso de error, mostramos datos de ejemplo
                setItems([
                    { label: 'YouTube Subs', value: '1.7K', platform: 'youtube', isLive: false },
                    { label: 'YouTube Views', value: '155K', platform: 'youtube', isLive: false }
                ]);
            }
        };
        fetchStats();
    }, [channelId]);

    return items;
}

// Importamos tu config de artista
import artistConfig from './artistConfig'

export default function HomePage() {
    const spotifyStats = useSpotifyStats(artistConfig.media.spotifyArtistId);
    const youtubeStats = useYoutubeStats(artistConfig.media.youtubeChannelId);
    
    // Usar el theme directamente
    const theme = getThemeDefinition(artistConfig);
    
    useEffect(() => {
        injectFonts(theme);
    }, [theme]);

    return (
        <ThemeContext.Provider value={theme}>
            <div className="min-h-screen" style={theme.cssVars as React.CSSProperties}>
                {/* Hero Section */}
                <HeroSection profile={artistConfig.profile} />
                
                {/* Stats Section */}
                <StatsSection 
                    profile={artistConfig.profile} 
                    spotifyStats={spotifyStats}
                    youtubeStats={youtubeStats}
                />
                
                {/* Media Hub */}
                <MediaHub media={artistConfig.media} />
                
                {/* Social Stack */}
                <SocialStack social={artistConfig.social} />
                
                {/* Booking */}
                <Booking booking={artistConfig.booking} />
                
                {/* Footer */}
                <Footer />
            </div>
        </ThemeContext.Provider>
    );
}

// Componentes simplificados sin theme dependencies
function HeroSection({ profile }: { profile: any }) {
    return (
        <section className="text-white py-20" style={{ backgroundColor: 'var(--color-primary)' }}>
            <div className="container mx-auto px-4 text-center">
                <h1 className="text-6xl font-bold mb-4">{profile.name}</h1>
                <p className="text-xl opacity-90">{profile.bio}</p>
            </div>
        </section>
    );
}

function StatsSection({ profile, spotifyStats, youtubeStats }: { profile: any, spotifyStats: any[], youtubeStats: any[] }) {
    return (
        <section className="py-16">
            <div className="container mx-auto px-4">
                <h2 className="text-3xl font-bold text-center mb-12" style={{ color: 'var(--color-text)' }}>
                    Estadísticas en Tiempo Real
                </h2>
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    {profile.stats.map((stat: any) => {
                        let liveValue = null;
                        
                        if (stat.isLive) {
                            if (stat.platform === 'spotify') {
                                const match = spotifyStats.find((s: any) => 
                                    s.label.toLowerCase().includes(stat.metric.toLowerCase())
                                );
                                if (match) liveValue = match.value;
                            } else if (stat.platform === 'youtube') {
                                const match = youtubeStats.find((s: any) => 
                                    s.label.toLowerCase().includes(stat.metric.toLowerCase())
                                );
                                if (match) liveValue = match.value;
                            }
                        }
                        
                        const displayValue = liveValue || stat.value;
                        
                        return (
                            <div key={stat.label} className="p-6 rounded-lg shadow-lg" style={{ backgroundColor: 'var(--color-bg)' }}>
                                <h3 className="text-lg font-semibold mb-2" style={{ color: 'var(--color-text)' }}>
                                    {stat.label}
                                </h3>
                                <p className="text-3xl font-bold" style={{ color: 'var(--color-primary)' }}>
                                    {displayValue}
                                </p>
                                {liveValue && (
                                    <span className="text-xs text-green-500 mt-2 block">🔴 LIVE</span>
                                )}
                            </div>
                        );
                    })}
                </div>
            </div>
        </section>
    );
}

